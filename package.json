{
	"name": "@iceman8911/tiny-prng",
	"description": "Simple 1kb Lehmer / Park-Miller pseudorandom number generator",
	"version": "0.2.0",
	"type": "module",
	"files": [
		"dist"
	],
	"exports": {
		"./prng": {
			"import": {
				"types": "./dist/prng.d.ts",
				"default": "./dist/prng.js"
			},
			"require": {
				"types": "./dist/prng.d.cts",
				"default": "./dist/prng.cjs"
			}
		},
		"./prng-immutable": {
			"import": {
				"types": "./dist/prng-immutable.d.ts",
				"default": "./dist/prng-immutable.js"
			},
			"require": {
				"types": "./dist/prng-immutable.d.cts",
				"default": "./dist/prng-immutable.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"lint": "biome check ./src",
		"lint:fix": "biome check --write ./src",
		"format": "biome format ./src",
		"format:fix": "biome format --write ./src",
		"tsc": "tsc --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"release": "bumpp --commit --push --tag",
		"publish:ci": "bun publish --access public --no-git-checks",
		"prepare": "husky"
	},
	"author": "patrick.triest@gmail.com",
	"contributors": [
		"iceman8911"
	],
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.1.3",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@types/bun": "^1.2.19",
		"bumpp": "^10.2.1",
		"bunup": "^0.16.31",
		"husky": "^9.1.7",
		"typescript": "^5.8.3"
	},
	"peerDependencies": {
		"typescript": ">=4.5.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Iceman8911/Tiny-PRNG.git"
	},
	"homepage": "https://github.com/Iceman8911/Tiny-PRNG#readme",
	"bugs": {
		"url": "https://github.com/Iceman8911/Tiny-PRNG/issues"
	}
}
